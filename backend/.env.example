# --- API server ---
PORT=3000

# CORS: comma-separated frontend origins (exact URL, no trailing slash).
# Include your Vercel URL, e.g. https://white-label-ai-chatbot-generator-ty.vercel.app
CORS_ORIGINS=https://white-label-ai-chatbot-generator-ty.vercel.app

# Optional: allow any *.vercel.app (previews). Prefer explicit CORS_ORIGINS in production.
# CORS_ALLOW_VERCEL=1

# --- Gmail (contact demo) ---
CONTACT_GMAIL_USER=
CONTACT_GMAIL_APP_PASSWORD=
# CONTACT_MAIL_FROM_NAME=SiteMind AI

# --- OpenAI (scrape structuring + chat test) ---
# OPENAI_API_KEY=
