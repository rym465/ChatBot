# --- API server ---
PORT=3000

# CORS is open (all origins) in server.js — no CORS_* vars needed.

# Where JSON files are stored (chatbots/, inquiries/). Use a persistent volume path in production.
# If unset: ./data when writable, else os.tmpdir()/wl-chatbot-data (Vercel/Lambda always use tmp).
# CONTEXT_DATA_DIR=/var/data/wl-chatbot

# --- Gmail (contact demo) ---
CONTACT_GMAIL_USER=
CONTACT_GMAIL_APP_PASSWORD=
# CONTACT_MAIL_FROM_NAME=SiteMind AI

# --- Scraping ---
# Selenium is tried first; if Chrome/Driver is missing (common on PaaS), the server falls back to HTTP+HTML parse.
# Force HTTP-only (no browser): SCRAPE_ENGINE=http
# SCRAPE_FETCH_TIMEOUT_MS=45000
# SCRAPE_USER_AGENT=Mozilla/5.0 ...

# --- OpenAI (scrape structuring + chat test) ---
# OPENAI_API_KEY=
